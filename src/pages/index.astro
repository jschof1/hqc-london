---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import LandingHeroSection from '../components/LandingHeroSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import SpecializedServicesSection from '../components/SpecializedServicesSection.astro';
import DifferentiationSection from '../components/DifferentiationSection.astro';
import AreasServed from '../components/AreasServed.astro';
import FounderStory from '../components/FounderStory.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import GuaranteeSection from '../components/GuaranteeSection.astro';
import TransformationGallery from '../components/TransformationGallery.astro';
import IntroRateBanner from '../components/IntroRateBanner.astro';
import siteSettings from '../data/site-settings.json';
---

<Layout title="High Quality Clean | London's Premier Luxury Home Cleaning Service">
  <Header />
  
  <main class="page-transition pt-16 relative">
	<!-- 1. Hero (Above the Fold) -->
	<div class="hero-transition">
		<LandingHeroSection />
	</div>
	<IntroRateBanner />

	<!-- 2. Social Proof Strip -->
	<TestimonialsSection />
	<!-- 7. Process Transparency -->
	<ProcessSteps />
	<!-- 4. Blue Ocean Differentiation -->
	<DifferentiationSection />
	<!-- 3. Service Tiers -->
	<ServicesSection />
	
	<!-- 3b. Specialized Services -->
	<SpecializedServicesSection />
	
	<!-- 5. Areas We Serve -->
	<AreasServed />
	<!-- 6. Founder Story -->
	<FounderStory />
	<!-- 8. Guarantee Section -->
	<GuaranteeSection />
	<!-- 9. Recent Work / Case Studies -->
	<TransformationGallery />

		<!-- 10. Final CTA -->
	<section
	  id="quote"
	  class="relative py-20 md:py-24 text-white parallax"
	  style="background-image: url('https://images.unsplash.com/photo-1622015663319-e97e697503ee?q=80&w=1600&auto=format&fit=crop'); background-size: cover; background-position: center; background-attachment: fixed;"
	>
	  <div
		class="absolute inset-0 bg-navy/70 backdrop-blur-sm"
		aria-hidden="true"
	  ></div>
	  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="text-center">
		  <h2 class="font-serif text-3xl md:text-5xl font-bold text-gold mb-6">
			Claim Your 30% Introductory Rate Today
		  </h2>
		  <p class="text-lg text-white/90 max-w-2xl mx-auto mb-8">
			Join hundreds of satisfied clients and experience the High Quality Clean difference. Limited availability for new clients.
		  </p>
		</div>

		<div class="text-center">
		  <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
			<a
			  href="/discount?type=home"
			  class="px-10 py-5 rounded-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl flex items-center justify-center gap-3 border-2 font-bold text-lg no-underline"
			  style="background-color: var(--color-gold); border-color: white; color: var(--color-navy);"
			>
			  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
				<polyline points="9 22 9 12 15 12 15 22"/>
			  </svg>
			  Claim 30% Home Rate
			</a>
			<a
			  href="/discount?type=commercial"
			  class="px-10 py-5 rounded-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl flex items-center justify-center gap-3 border-2 font-bold text-lg no-underline"
			  style="background-color: white; border-color: var(--color-gold); color: var(--color-navy);"
			>
			  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<rect x="3" y="2" width="18" height="20" rx="2" ry="2"/>
				<path d="M9 22V12h6v10"/>
				<path d="M9 6h.01M12 6h.01M15 6h.01M9 10h.01M12 10h.01M15 10h.01"/>
			  </svg>
			  Claim 30% Commercial Rate
			</a>
		  </div>
		  <p class="text-white/60 text-sm">
			Limited availability &bull; 12-month agreement required &bull; No credit card needed
		  </p>
		</div>
	  </div>
	</section>
  </main>
</Layout>