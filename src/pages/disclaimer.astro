---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import IntroRateBanner from '../components/IntroRateBanner.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Layout 
  title="Third Party Disclaimer | High Quality Clean"
  description="Important information about external links, third-party platforms, and third-party services referenced on the High Quality Clean Ltd website."
>
  <Header />
  
  <main class="page-transition pt-16">
    <!-- Hero Section -->
    <section class="bg-navy py-20 md:py-28">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold/20 mb-6">
            <i class="fas fa-info-circle text-gold text-2xl"></i>
          </div>
          <h1 class="font-serif text-4xl md:text-5xl text-white font-semibold mb-6">
            Third Party Disclaimer
          </h1>
          <p class="text-white/80 text-lg">
            Important information about external links and third-party services
          </p>
        </div>
      </div>
    </section>
    <IntroRateBanner />

    <!-- Main Content -->
    <section class="py-16 md:py-20 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">

        <div class="prose prose-gold max-w-none text-ink/80">
          <p class="text-lg leading-relaxed mb-4">
            This disclaimer applies to external links, third-party platforms, and third-party services referenced on the High Quality Clean Ltd website (<a href="https://www.highqualityclean.co.uk" class="text-gold hover:text-navy">highqualityclean.co.uk</a>).
          </p>
          <p class="leading-relaxed mb-12">
            This disclaimer should be read alongside our <a href="/terms-and-conditions" class="text-gold hover:text-navy">Terms and Conditions</a> and <a href="/privacy-policy" class="text-gold hover:text-navy">Privacy Policy</a>.
          </p>

          <!-- 1. External Links -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">1. External Links</h2>
            <p class="mb-4">Our website may contain links to third-party websites for your convenience and information.</p>
            <p class="mb-3">High Quality Clean Ltd:</p>
            <ul class="list-disc pl-6 space-y-2 mb-4">
              <li>Does not control third-party websites</li>
              <li>Does not endorse or guarantee third-party content unless expressly stated</li>
              <li>Is not responsible for the content, security, or availability of third-party websites</li>
            </ul>
            <p>You access third-party websites at your own risk and should review their own terms and privacy policies before using them.</p>
          </div>

          <!-- 2. Review Platforms -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">2. Review Platforms &amp; Business Directories</h2>
            <p class="mb-3">We maintain profiles on review platforms and directories such as (but not limited to):</p>
            <ul class="list-disc pl-6 space-y-2 mb-4">
              <li>Google Business Profile</li>
              <li>Yell</li>
              <li>Bark</li>
              <li>Checkatrade</li>
              <li>Social media platforms</li>
            </ul>
            <p class="mb-3">Please note:</p>
            <ul class="list-disc pl-6 space-y-2">
              <li>Reviews are submitted by independent third parties.</li>
              <li>We do not control the content of reviews posted externally.</li>
              <li>Ratings reflect individual experiences and may not represent typical results.</li>
              <li>Information on third-party platforms may not always reflect our most recent services, pricing, or policies.</li>
            </ul>
          </div>

          <!-- 3. Social Media -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">3. Social Media Platforms</h2>
            <p class="mb-4">We maintain business pages on platforms including Instagram, Facebook, LinkedIn, TikTok and others.</p>
            <p class="mb-3">These platforms:</p>
            <ul class="list-disc pl-6 space-y-2 mb-4">
              <li>Are operated independently from High Quality Clean Ltd</li>
              <li>Have their own terms of service and privacy policies</li>
              <li>Control user-generated content and comments</li>
            </ul>
            <p>We are not responsible for content posted by third-party users on social media platforms.</p>
          </div>

          <!-- 4. Payment Processors -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">4. Payment Processors &amp; Third-Party Services</h2>
            <p class="mb-3">We use reputable third-party providers for certain business functions, including but not limited to:</p>
            <ul class="list-disc pl-6 space-y-2 mb-4">
              <li>Stripe (payment processing)</li>
              <li>Scheduling or booking platforms</li>
              <li>CRM and email systems</li>
              <li>Analytics tools</li>
            </ul>
            <p class="mb-3">These providers operate under their own terms and privacy policies.</p>
            <p class="mb-3">While we select reputable providers, we:</p>
            <ul class="list-disc pl-6 space-y-2 mb-4">
              <li>Do not control their systems</li>
              <li>Cannot guarantee uninterrupted third-party service availability</li>
              <li>Are not liable for service outages caused by third-party systems beyond our reasonable control</li>
            </ul>
            <p>You should review the privacy policies of any third-party service used in connection with our Services.</p>
          </div>

          <!-- 5. Product, Brand & Service References -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">5. Product, Brand &amp; Service References</h2>
            <p class="mb-3">From time to time, we may reference third-party brands, products, or services.</p>
            <p class="mb-3">Unless expressly stated:</p>
            <ul class="list-disc pl-6 space-y-2">
              <li>Such references do not constitute endorsement or partnership.</li>
              <li>Trademarks and logos remain the property of their respective owners.</li>
              <li>We are not responsible for the performance, availability, or safety of third-party products.</li>
            </ul>
          </div>

          <!-- 6. No Affiliation -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">6. No Affiliation</h2>
            <p class="mb-3">Unless expressly stated in writing:</p>
            <ul class="list-disc pl-6 space-y-2">
              <li>We are not affiliated with, sponsored by, or endorsed by third-party organisations mentioned on this website.</li>
              <li>Any mention of third parties is for informational purposes only.</li>
            </ul>
          </div>

          <!-- 7. Testimonials & Case Studies -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">7. Testimonials &amp; Case Studies</h2>
            <p class="mb-3">Testimonials published on our website reflect genuine client experiences.</p>
            <p class="mb-3">However:</p>
            <ul class="list-disc pl-6 space-y-2">
              <li>Results may vary depending on property condition and scope of service.</li>
              <li>Testimonials represent individual client opinions.</li>
              <li>They do not guarantee identical outcomes in every case.</li>
            </ul>
          </div>

          <!-- 8. Limitation of Liability -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">8. Limitation of Liability</h2>
            <p class="mb-4">Nothing in this disclaimer excludes or limits liability where such exclusion is not permitted under the laws of England and Wales.</p>
            <p class="mb-3">Subject to that:</p>
            <p class="mb-3">High Quality Clean Ltd shall not be liable for any loss or damage arising from:</p>
            <ul class="list-disc pl-6 space-y-2 mb-4">
              <li>Reliance on third-party content</li>
              <li>Use of third-party websites</li>
              <li>Third-party system outages beyond our control</li>
            </ul>
            <p>This disclaimer should be read together with our main <a href="/terms-and-conditions" class="text-gold hover:text-navy">Terms and Conditions</a>, which govern the provision of our Services.</p>
          </div>

          <!-- 9. Updates -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">9. Updates</h2>
            <p>We may update this disclaimer from time to time. Updates will take effect when published on this website.</p>
          </div>

          <!-- 10. Contact -->
          <div class="mb-10">
            <h2 class="font-serif text-2xl md:text-3xl text-navy font-semibold mb-4">10. Contact</h2>
            <p class="mb-4">If you have any questions regarding this disclaimer, please contact:</p>
            <div class="bg-navy/5 rounded-xl p-6 border border-gold/20">
              <p class="font-semibold text-navy mb-2">High Quality Clean Ltd</p>
              <div class="space-y-2">
                <div class="flex items-center gap-3">
                  <i class="fas fa-envelope text-gold"></i>
                  <a href="mailto:sales@highqualityclean.co.uk" class="text-gold hover:text-navy transition-colors font-medium">
                    sales@highqualityclean.co.uk
                  </a>
                </div>
                <div class="flex items-center gap-3">
                  <i class="fas fa-phone text-gold"></i>
                  <a href="tel:+442088703925" class="text-gold hover:text-navy transition-colors font-medium">
                    +44 20 8870 3925
                  </a>
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- Last Updated -->
        <div class="text-center pt-8 border-t border-gold/20 mt-12">
          <p class="text-ink/60 text-sm">
            <i class="far fa-calendar-alt text-gold mr-2"></i>
            Last updated: April 29, 2026
          </p>
        </div>

      </div>
    </section>

    <!-- CTA Banner -->
    <CTABanner />
  </main>
</Layout>
