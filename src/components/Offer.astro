---
// src/pages/index.astro
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HQC London - Premium Cleaning Services</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <style>
      :root {
        --color-navy: #2c3e50;
        --color-night: #1c2833;
        --color-gold: #c9a961;
        --color-mist: #f5f5f0;
        --color-ink: #1a1a2e;
        --font-display: Georgia, "Times New Roman", serif;
        --font-body: system-ui, -apple-system, sans-serif;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: var(--font-body);
        background-color: #ffffff;
      }
    </style>
  </head>
  <body class="min-h-screen">

    <!-- SECTION 1: GLOBAL HEADER (STICKY) -->
    <header id="site-header" class="site-header">
      <div class="header-inner">
        <div class="logo">HQC</div>

        <nav class="header-nav">
          <button
            class="btn-outline"
            data-form-type="home"
            data-scroll-to-form
          >
            30% Home Cleaning Intro
          </button>
          <button
            class="btn-outline"
            data-form-type="commercial"
            data-scroll-to-form
          >
            30% Commercial Intro
          </button>
          <a href="tel:+442088703925" class="btn-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </nav>
      </div>
    </header>

    <!-- SECTION 2: HERO -->
    <section class="hero-section">
      <div
        class="hero-bg-image"
        style="background-image: url('https://images.unsplash.com/photo-1766371900890-696edc6c7fc9?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxsdXh1cnklMjBtb2Rlcm4lMjBjbGVhbiUyMGludGVyaW9yfGVufDF8fHx8MTc3MTg0Mjk5OHww&ixlib=rb-4.1.0&q=80&w=1080');"
      ></div>

      <div class="hero-inner">
        <div class="hero-grid">
          <!-- LEFT: MESSAGE -->
          <div class="hero-content">
            <div class="hero-text">
              <h1 class="hero-h1">
                30% Introductory Rate for Your First Month
              </h1>
              <p class="hero-sub">
                When You Secure a 12-Month Cleaning Agreement
              </p>
              <p class="hero-body">
                Premium, contract-led cleaning for homes and businesses.<br />
                Clear pricing. Quality control. No surprises.
              </p>
            </div>

            <div class="hero-buttons">
              <button
                class="btn-gold-lg"
                data-form-type="home"
                data-scroll-to-form
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Claim My Home Intro Rate
              </button>
              <button
                class="btn-outline-lg"
                data-form-type="commercial"
                data-scroll-to-form
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
                Claim My Commercial Intro Rate
              </button>
            </div>

            <!-- TRUST SIGNALS -->
            <div class="trust-grid-wrapper">
              <div class="trust-grid">
                <div class="trust-item">
                  <div class="trust-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  </div>
                  <div>
                    <p class="trust-title">Fully Insured</p>
                    <p class="trust-sub">£5M Coverage</p>
                  </div>
                </div>
                <div class="trust-item">
                  <div class="trust-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  </div>
                  <div>
                    <p class="trust-title">Quality Guaranteed</p>
                    <p class="trust-sub">100% Satisfaction</p>
                  </div>
                </div>
                <div class="trust-item">
                  <div class="trust-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  </div>
                  <div>
                    <p class="trust-title">500+ Clients</p>
                    <p class="trust-sub">Across London</p>
                  </div>
                </div>
                <div class="trust-item">
                  <div class="trust-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                  </div>
                  <div>
                    <p class="trust-title">15+ Years</p>
                    <p class="trust-sub">In Business</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- BADGES -->
            <div class="badge-row">
              <div class="stars">
                {
                  [1, 2, 3, 4, 5].map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))
                }
                <span class="badge-text">5/5 Rating</span>
              </div>
              <div class="divider-v"></div>
              <span class="badge-text">DBS Checked Staff</span>
              <div class="divider-v"></div>
              <span class="badge-text">Eco-Friendly Products</span>
            </div>
          </div>

          <!-- RIGHT: FORM -->
          <div id="lead-form" class="hero-form-col">
            <!-- LeadForm island goes here -->
            <!-- Replace with your React/Svelte/etc. island -->
            <div class="form-placeholder">
              <div class="form-box">
                <h3 class="form-title">Get Your 30% Intro Rate</h3>
                <p class="form-sub">Fill in your details and we'll be in touch within 24 hours.</p>
                <form class="enquiry-form" id="enquiry-form">
                  <input type="hidden" name="type" id="form-type" value="home" />
                  <div class="form-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" placeholder="Your name" required />
                  </div>
                  <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" placeholder="your@email.com" required />
                  </div>
                  <div class="form-group">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" placeholder="+44..." />
                  </div>
                  <div class="form-group">
                    <label for="message">Tell us about your property</label>
                    <textarea id="message" name="message" rows="3" placeholder="e.g. 3-bed house, weekly clean..."></textarea>
                  </div>
                  <button type="submit" class="btn-form-submit">
                    Claim My Introductory Rate
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: WHO THIS IS FOR -->
    <section class="section-mist py-20">
      <div class="container">
        <h2 class="section-heading-dark">
          Trusted by clients who value consistency and control
        </h2>
        <div class="gold-divider"></div>

        <div class="two-col-grid mt-12">
          <!-- Residential -->
          <div class="service-card">
            <div
              class="card-image"
              style="background-image: url('https://images.unsplash.com/photo-1767050321604-a2654be8fad0?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxsdXh1cnklMjByZXNpZGVudGlhbCUyMGhvbWUlMjBpbnRlcmlvcnxlbnwxfHx8fDE3NzE4NDMyOTJ8MA&ixlib=rb-4.1.0&q=80&w=1080');"
            >
              <div class="card-image-overlay"></div>
            </div>
            <div class="card-body">
              <div class="card-icon-row">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <h3 class="card-title">Residential Plans</h3>
              </div>
              <ul class="check-list">
                {["Essentials Clean™", "Signature Clean™", "WellClean™"].map((s) => (
                  <li class="check-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold); flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <span>{s}</span>
                  </li>
                ))}
              </ul>
              <div class="card-footer">
                <p>12-month plans • 30% first month • fixed pricing</p>
              </div>
            </div>
          </div>

          <!-- Commercial -->
          <div class="service-card">
            <div
              class="card-image"
              style="background-image: url('https://images.unsplash.com/photo-1758630737900-a28682c5aa69?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBjb21tZXJjaWFsJTIwb2ZmaWNlJTIwc3BhY2V8ZW58MXx8fHwxNzcxODQzMjkzfDA&ixlib=rb-4.1.0&q=80&w=1080');"
            >
              <div class="card-image-overlay"></div>
            </div>
            <div class="card-body">
              <div class="card-icon-row">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
                <h3 class="card-title">Commercial &amp; Advisory</h3>
              </div>
              <ul class="check-list">
                {
                  [
                    "HQC Office Clean™",
                    "WellClean™ Studio Advisory",
                    "WellClean™ Studio Edition",
                  ].map((s) => (
                    <li class="check-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold); flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                      <span>{s}</span>
                    </li>
                  ))
                }
              </ul>
              <div class="card-footer">
                <p>Contract-led • priority service • predictable costs</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 4: HOW IT WORKS -->
    <section class="section-white py-20">
      <div class="container-sm">
        <h2 class="section-heading-dark">How the Introductory Rate Works</h2>

        <div class="steps-grid">
          {
            [
              { step: "1", text: "Join on a 12-month agreement" },
              { step: "2", text: "Receive 30% off your first month" },
              { step: "3", text: "Ongoing rate is agreed upfront and locked" },
              { step: "4", text: "Normal plan pricing applies from month two" },
            ].map((item) => (
              <div class="step-item">
                <div class="step-number">{item.step}</div>
                <p class="step-text">{item.text}</p>
              </div>
            ))
          }
        </div>

        <div class="transparency-bar">
          {
            ["No stacked discounts", "No surprises", "Full transparency"].map(
              (point) => (
                <div class="transparency-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  <span>{point}</span>
                </div>
              )
            )
          }
        </div>
      </div>
    </section>

    <!-- SECTION 5: PROJECT SERVICES -->
    <section class="section-navy py-20">
      <div class="container">
        <h2 class="section-heading-light">
          Project &amp; Specialist Cleaning Services
        </h2>
        <div class="gold-divider"></div>
        <p class="section-body-light">
          Professional project-based cleaning tailored to your specific needs.
          Each service is delivered with the same quality standards that define
          HQC.
        </p>

        <div class="three-col-grid">
          {
            [
              {
                title: "Post-Construction Clean",
                cta: "Request an Assessment",
                image:
                  "https://images.unsplash.com/photo-1634674346387-63c94e4fdae7?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjb25zdHJ1Y3Rpb24lMjBzaXRlJTIwY2xlYW5pbmclMjBwcm9mZXNzaW9uYWx8ZW58MXx8fHwxNzcxODQzMjkzfDA&ixlib=rb-4.1.0&q=80&w=1080",
                description:
                  "Transform construction sites into move-in ready spaces with our comprehensive post-build cleaning service.",
                features: [
                  "Dust & debris removal",
                  "Window & fixture cleaning",
                  "Surface sanitization",
                  "Final inspection ready",
                ],
              },
              {
                title: "Airbnb Turnover Clean",
                cta: "Discuss Your Property",
                image:
                  "https://images.unsplash.com/photo-1521783593447-5702b9bfd267?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxhaXJibmIlMjB2YWNhdGlvbiUyMHJlbnRhbCUyMGludGVyaW9yfGVufDF8fHx8MTc3MTg0MzI5M3ww&ixlib=rb-4.1.0&q=80&w=1080",
                description:
                  "Keep your rental property pristine between guests with our rapid-response turnover cleaning service.",
                features: [
                  "Same-day availability",
                  "Linen & towel service",
                  "Guest-ready standards",
                  "Photo-ready presentation",
                ],
              },
              {
                title: "Move In / Move Out Reset™",
                cta: "Get a Reset Quote",
                image:
                  "https://images.unsplash.com/photo-1580451299338-3658f5b11930?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxtb3ZpbmclMjBib3hlcyUyMG5ldyUyMGhvbWV8ZW58MXx8fHwxNzcxODE2NDcyfDA&ixlib=rb-4.1.0&q=80&w=1080",
                description:
                  "Start fresh or leave perfectly with our deep-clean service designed for property transitions.",
                features: [
                  "Deep clean all rooms",
                  "Appliance detailing",
                  "Deposit protection",
                  "Landlord approved",
                ],
              },
            ].map((service) => (
              <div class="project-card">
                <div
                  class="project-card-image"
                  style={`background-image: url('${service.image}');`}
                >
                  <div class="project-card-overlay">
                    <div class="project-card-title-area">
                      <div class="gold-line" />
                      <h3 class="project-card-title">{service.title}</h3>
                    </div>
                  </div>
                </div>
                <div class="project-card-body">
                  <p class="project-desc">{service.description}</p>
                  <ul class="check-list mb-6">
                    {service.features.map((f) => (
                      <li class="check-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold); flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span class="text-sm">{f}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="quality-badge-row">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <span class="quality-badge-text">HQC Quality Assured</span>
                  </div>
                  <button
                    class="btn-full-gold"
                    data-form-type="general"
                    data-scroll-to-form
                  >
                    {service.cta}
                  </button>
                </div>
              </div>
            ))
          }
        </div>

        <div class="portfolio-note">
          <p class="portfolio-note-title">
            Looking for portfolio or multi-site solutions?
          </p>
          <p class="portfolio-note-sub">
            Selective 30% introductory rates available for landlords and
            commercial property managers
          </p>
        </div>
      </div>
    </section>

    <!-- SECTION 6: SPECIALIST ADD-ONS -->
    <section class="section-mist py-16">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-heading-navy">Specialist Add-On Services</h2>
          <div class="gold-divider"></div>
          <p class="section-body-navy max-w-2xl mx-auto">
            Elevate your cleaning plan with premium add-ons. Available with any
            12-month agreement.
          </p>
        </div>

        <div class="addon-grid">
          {
            [
              {
                title: "Professional Ironing & Laundry",
                description:
                  "Expert garment care with collection and delivery service included",
                benefits: [
                  "Pick-up & drop-off",
                  "Same-week turnaround",
                  "Delicate fabric expertise",
                ],
                image:
                  "https://images.unsplash.com/photo-1582735689369-4fe89db7114c?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxpcm9uaW5nJTIwbGF1bmRyeSUyMHNlcnZpY2V8ZW58MXx8fHwxNzcxODQ5MDAwfDA&ixlib=rb-4.1.0&q=80&w=1080",
              },
              {
                title: "Premium Window Cleaning",
                description:
                  "Streak-free clarity inside and out using professional equipment",
                benefits: [
                  "Interior & exterior",
                  "Frame & sill detailing",
                  "High-reach capability",
                ],
                image:
                  "https://images.unsplash.com/photo-1628177142898-93e36e4e3a50?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHx3aW5kb3clMjBjbGVhbmluZyUyMHByb2Zlc3Npb25hbHxlbnwxfHx8fDE3NzE4NDkwMDB8MA&ixlib=rb-4.1.0&q=80&w=1080",
              },
              {
                title: "Carpet & Upholstery Deep Clean",
                description:
                  "Hot water extraction for thorough restoration of fabrics",
                benefits: [
                  "Stain removal",
                  "Odour elimination",
                  "Fast-dry technology",
                ],
                image:
                  "https://images.unsplash.com/photo-1581578731548-c64695cc6952?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjYXJwZXQlMjBjbGVhbmluZyUyMHByb2Zlc3Npb25hbHxlbnwxfHx8fDE3NzE4NDkwMDB8MA&ixlib=rb-4.1.0&q=80&w=1080",
              },
              {
                title: "Oven Deep Cleaning",
                description:
                  "Restore your oven to showroom condition with eco-friendly solutions",
                benefits: [
                  "Non-toxic products",
                  "All oven types",
                  "Hob & extractor included",
                ],
                image:
                  "https://images.unsplash.com/photo-1556909212-d5b604d0c90d?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjbGVhbiUyMG92ZW4lMjBraXRjaGVufGVufDF8fHx8MTc3MTg0OTAwMHww&ixlib=rb-4.1.0&q=80&w=1080",
              },
              {
                title: "Exterior Pressure Washing",
                description:
                  "High-power cleaning for driveways, patios, and building facades",
                benefits: [
                  "Concrete & stone safe",
                  "Moss & algae removal",
                  "Sealed finish option",
                ],
                image:
