<script>
  // ── Sticky header scroll effect ────────────────────────────────
  const header = document.getElementById("site-header");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  });

  // ── Scroll-to-form + set active type ──────────────────────────
  const formTypeInput = document.getElementById(
    "form-type"
  ) as HTMLInputElement | null;
  const formTitleEl = document.querySelector(".form-title");
  const formSubEl = document.querySelector(".form-sub");

  const typeLabels: Record<string, { title: string; sub: string }> = {
    home: {
      title: "Claim Your 30% Home Intro Rate",
      sub: "Fill in your details and we'll be in touch within 24 hours.",
    },
    commercial: {
      title: "Claim Your 30% Commercial Intro Rate",
      sub: "Fill in your details and we'll be in touch within 24 hours.",
    },
    general: {
      title: "Build Your Custom Package",
      sub: "Tell us what you need and we'll put together a tailored quote.",
    },
  };

  function scrollToForm(type: string) {
    const formEl = document.getElementById("lead-form");
    if (formEl) {
      formEl.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    if (formTypeInput) formTypeInput.value = type;

    const labels = typeLabels[type];
    if (labels) {
      if (formTitleEl) formTitleEl.textContent = labels.title;
      if (formSubEl) formSubEl.textContent = labels.sub;
    }

    // Update tab active state
    document.querySelectorAll<HTMLButtonElement>(".form-tab").forEach((tab) => {
      tab.classList.toggle("active", tab.dataset.type === type);
    });
  }

  document
    .querySelectorAll<HTMLButtonElement>("[data-scroll-to-form]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const type = btn.dataset.formType ?? "general";
        scrollToForm(type);
      });
    });

  // Tab clicks inside the form
  document
    .querySelectorAll<HTMLButtonElement>(".form-tab")
    .forEach((tab) => {
      tab.addEventListener("click", () => {
        scrollToForm(tab.dataset.type ?? "general");
      });
    });

  // ── Basic form submission handler ─────────────────────────────
  document
    .getElementById("enquiry-form")
    ?.addEventListener("submit", (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const submitBtn = form.querySelector<HTMLButtonElement>(
        ".btn-form-submit"
      );
      if (submitBtn) {
        submitBtn.textContent = "Thank you! We'll be in touch soon.";
        submitBtn.disabled = true;
        submitBtn.style.opacity = "0.7";
      }
      // Wire up your actual submission logic here (fetch, formspree, etc.)
    });
</script>